{
  "name": "gorda-api",
  "version": "2.0.1",
  "description": "WhatsApp chatbot to gorda admin",
  "main": "src/app.ts",
  "scripts": {
    "build": "tsc -p . && cp -r src/.well-known build/src/.well-known && cp -r src/views build/src/views && cp -r src/assets build/src/assets",
    "serve": "tsc && node build/src/app.js",
    "watch": "nodemon src/app.ts --ignore 'storage/'",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "format:all": "prettier --write \"./**/*.{ts,js,json}\" --ignore-path .gitignore",
    "migrate:sql:development": "NODE_ENV=development sequelize-cli db:migrate --env development",
    "migrate:sql:production": "NODE_ENV=production sequelize-cli db:migrate --env production",
    "backfill:phase1:users": "ts-node src/Migration/phase1MasterDataBackfill.ts users",
    "backfill:phase1:drivers": "ts-node src/Migration/phase1MasterDataBackfill.ts drivers",
    "backfill:phase1:wp-clients": "ts-node src/Migration/phase1MasterDataBackfill.ts wp_clients",
    "backfill:phase1:ride-fees": "ts-node src/Migration/phase1MasterDataBackfill.ts ride_fees",
    "backfill:phase1:chatbot-messages": "ts-node src/Migration/phase1MasterDataBackfill.ts chatbot_messages",
    "backfill:phase1:branches": "ts-node src/Migration/phase1MasterDataBackfill.ts branches",
    "backfill:phase1:all": "ts-node src/Migration/phase1MasterDataBackfill.ts all",
    "backfill:phase2:service-history": "ts-node src/Migration/phase2ServiceHistoryBackfill.ts service_history",
    "backfill:phase2:service-metrics": "ts-node src/Migration/phase2ServiceHistoryBackfill.ts service_metrics",
    "backfill:phase2:all": "ts-node src/Migration/phase2ServiceHistoryBackfill.ts all",
    "backfill:phase3:driver-tokens": "ts-node src/Migration/phase3DriverTokensBackfill.ts",
    "cleanup:firebase:rtdb": "ts-node src/Migration/phase5FirebaseCleanup.ts rtdb",
    "cleanup:firebase:firestore:daily": "ts-node src/Migration/phase5FirebaseCleanup.ts firestore-daily",
    "release:sql:production": "NODE_ENV=production npm run migrate:sql:production && NODE_ENV=production npm run backfill:phase1:all && NODE_ENV=production npm run backfill:phase2:all && NODE_ENV=production npm run backfill:phase3:driver-tokens",
    "verify:release": "npm run build && npm run format:check"
  },
  "keywords": [
    "chat",
    "bot",
    "whatsapp",
    "api"
  ],
  "author": "devalexandrecr@gmail.com",
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@huggingface/inference": "^2.6.4",
    "@sentry/node": "^7.5.0",
    "@sentry/tracing": "^7.5.0",
    "@turf/turf": "^7.1.0",
    "@types/node-cache": "^4.1.3",
    "@whiskeysockets/baileys": "6.7.9",
    "axios": "^1.4.0",
    "bullmq": "^5.41.7",
    "dayjs": "^1.11.1",
    "dotenv": "^16.0.0",
    "express": "^4.17.3",
    "firebase-admin": "^11.4.1",
    "i18n": "^0.15.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "pino": "^9.1.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.4.1",
    "whatsapp-web.js": "^v1.25.0",
    "xml2js": "^0.6.2",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/i18n": "^0.13.4",
    "@types/node": "^17.0.22",
    "@types/node-cron": "^3.0.4",
    "@types/pg": "^8.10.7",
    "@types/qrcode-terminal": "^0.12.0",
    "@types/sequelize": "^4.28.16",
    "@types/socket.io": "^3.0.2",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "nodemon": "^2.0.15",
    "prettier": "^3.6.2",
    "sequelize-cli": "^6.6.1",
    "ts-node": "^10.7.0",
    "typescript": "^5.1.6"
  }
}
